---
interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;
const isAr = lang === 'ar';
---

<nav class="fixed w-full z-50 top-0 transition-all duration-500" id="navbar">
  <div class="max-w-[1400px] mx-auto px-4 md:px-6 py-4 md:py-6 flex justify-between items-center">
    <a
      href={isAr ? '/ar' : '/'}
      class="text-xl md:text-2xl font-bold font-display tracking-tighter flex items-center gap-2 md:gap-3 z-50 relative hover:opacity-80 transition-opacity"
    >
      <img src="/logo.png" alt="Digital Hype Logo" class="h-8 w-8 object-contain" width="32" height="32" />
      <span>DIGITAL HYPE</span>
      <span class="flex gap-1">
        <span class="w-1.5 h-1.5 bg-[#CE1126] rounded-full"></span>
        <span class="w-1.5 h-1.5 bg-white rounded-full"></span>
        <span class="w-1.5 h-1.5 bg-[#00732F] rounded-full"></span>
      </span>
    </a>

    <div class="hidden md:flex space-x-10 text-sm font-medium text-gray-400">
      <a href={isAr ? '/ar#why-it-works' : '/#why-it-works'} class="hover:text-white transition-colors">
        {isAr ? 'لماذا يعمل' : 'Why it works'}
      </a>
      <a href="/case-studies" class="hover:text-white transition-colors">
        {isAr ? 'دراسات الحالة' : 'Case Studies'}
      </a>
      <a href="/roi-calculator" class="hover:text-white transition-colors">
        {isAr ? 'حاسبة العائد' : 'ROI Calculator'}
      </a>
      <a href={isAr ? '/ar#process' : '/#process'} class="hover:text-white transition-colors">
        {isAr ? 'العملية' : 'Process'}
      </a>
    </div>

    <a
      href={isAr ? '/ar#get-started' : '/#get-started'}
      class="hidden md:inline-flex magnetic-btn group relative px-6 py-3 bg-white text-black text-sm font-bold rounded-full overflow-hidden z-50"
    >
      <span class="relative z-10 group-hover:text-white transition-colors duration-300">
        {isAr ? 'ابدأ الآن' : 'Get Started'}
      </span>
      <div class="absolute inset-0 h-full w-0 bg-[#CE1126] transition-all duration-300 ease-out group-hover:w-full"></div>
    </a>

    <button
      id="mobile-menu-btn"
      aria-label="Toggle Mobile Menu"
      class="md:hidden relative z-50 text-white p-2 focus:outline-none"
    >
      <svg id="menu-icon-open" class="w-6 h-6 transition-opacity duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg id="menu-icon-close" class="w-6 h-6 absolute top-2 left-2 opacity-0 transition-opacity duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="fixed top-0 right-0 h-[100dvh] w-full bg-black/95 backdrop-blur-2xl z-40 flex flex-col items-center justify-center translate-x-full transition-transform duration-300 md:hidden">
    <div class="flex flex-col items-center gap-8 text-2xl font-display font-medium">
      <a href={isAr ? '/ar#why-it-works' : '/#why-it-works'} class="mobile-link text-gray-400 hover:text-white transition-colors">
        {isAr ? 'لماذا يعمل' : 'Why it works'}
      </a>
      <a href="/case-studies" class="mobile-link text-gray-400 hover:text-white transition-colors">
        {isAr ? 'دراسات الحالة' : 'Case Studies'}
      </a>
      <a href="/roi-calculator" class="mobile-link text-gray-400 hover:text-white transition-colors">
        {isAr ? 'حاسبة العائد' : 'ROI Calculator'}
      </a>
      <a href={isAr ? '/ar#process' : '/#process'} class="mobile-link text-gray-400 hover:text-white transition-colors">
        {isAr ? 'العملية' : 'Process'}
      </a>
      <a
        href={isAr ? '/ar#get-started' : '/#get-started'}
        class="mobile-link mt-4 px-8 py-4 bg-white text-black text-lg font-bold rounded-full"
      >
        {isAr ? 'ابدأ الآن' : 'Get Started'}
      </a>
    </div>
  </div>
</nav>
